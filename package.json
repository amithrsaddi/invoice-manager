{
  "name": "invoice-manager",
  "private": true,
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm --prefix frontend run build",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "typecheck:functions": "tsc --noEmit -p ./netlify/functions/tsconfig.json",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend && npm run typecheck:functions"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.2",
    "mongoose": "^8.19.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.8.2"
  }
}
